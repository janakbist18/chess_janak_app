# Environment Configuration
# API Configuration
API_BASE_URL=https://api.chessjanak.com
WEBSOCKET_URL=wss://ws.chessjanak.com

# Firebase Configuration
FIREBASE_PROJECT_ID=chess-janak
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=chess-janak.firebaseapp.com
FIREBASE_STORAGE_BUCKET=chess-janak.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID

# App Configuration
APP_NAME=Chess Janak
APP_VERSION=1.0.0
ENABLE_DEBUG_LOGGING=true
